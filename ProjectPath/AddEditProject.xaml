<Window x:Class="ProjectPath.AddEditProject"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectPath"
        mc:Ignorable="d"
         Title="Добавление/Редактирование проекта" Height="500" Width="600"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Название -->
        <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBox x:Name="tbName" Grid.Row="0" Grid.Column="1" Margin="0,5" Text="{Binding Name}"/>

        <!-- Руководитель -->
        <TextBlock Grid.Row="1" Grid.Column="0" Text="Руководитель:" VerticalAlignment="Center" FontWeight="Bold"/>
        <ComboBox x:Name="cbSupervisor" Grid.Row="1" Grid.Column="1" Margin="0,5"
                  DisplayMemberPath="LastName" SelectedValuePath="EmployeeId"
                  SelectedValue="{Binding Supervisor}"/>

        <!-- Отдел -->
        <TextBlock Grid.Row="2" Grid.Column="0" Text="Отдел:" VerticalAlignment="Center" FontWeight="Bold"/>
        <ComboBox x:Name="cbDepartment" Grid.Row="2" Grid.Column="1" Margin="0,5"
                  DisplayMemberPath="Name" SelectedValuePath="DepartmentId"
                  SelectedValue="{Binding DepartmentId}"/>

        <!-- Заказчик -->
        <TextBlock Grid.Row="3" Grid.Column="0" Text="Заказчик:" VerticalAlignment="Center" FontWeight="Bold"/>
        <ComboBox x:Name="cbCustomer" Grid.Row="3" Grid.Column="1" Margin="0,5"
                  DisplayMemberPath="NameOrganization" SelectedValuePath="CustomerId"
                  SelectedValue="{Binding CustomerId}"/>

        <!-- Стоимость -->
        <TextBlock Grid.Row="4" Grid.Column="0" Text="Стоимость:" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBox x:Name="tbCost" Grid.Row="4" Grid.Column="1" Margin="0,5" 
                 Text="{Binding EstimatedDesignCost, StringFormat={}{0}}"/>

        <!-- Статус -->
        <TextBlock Grid.Row="5" Grid.Column="0" Text="Статус:" VerticalAlignment="Center" FontWeight="Bold"/>
        <ComboBox x:Name="cbStatus" Grid.Row="5" Grid.Column="1" Margin="0,5" 
          SelectedValue="{Binding Status}" SelectedValuePath="Content">
            <ComboBoxItem Content="Активный"/>
            <ComboBoxItem Content="Завершён"/>
            <ComboBoxItem Content="Заморожен"/>
            <ComboBoxItem Content="Планирование"/>
        </ComboBox>

        <!-- Дата старта -->
        <TextBlock Grid.Row="6" Grid.Column="0" Text="Дата старта:" VerticalAlignment="Center" FontWeight="Bold"/>
        <DatePicker x:Name="dpStartDate" Grid.Row="6" Grid.Column="1" Margin="0,5"
                    SelectedDate="{Binding StartDate}"/>

        <!-- Плановая дата -->
        <TextBlock Grid.Row="7" Grid.Column="0" Text="Плановая дата:" VerticalAlignment="Center" FontWeight="Bold"/>
        <DatePicker x:Name="dpPlannedDate" Grid.Row="7" Grid.Column="1" Margin="0,5"
                    SelectedDate="{Binding PlannedCompletionDate}"/>

        <!-- Фактическая дата -->
        <TextBlock Grid.Row="8" Grid.Column="0" Text="Факт. дата:" VerticalAlignment="Center" FontWeight="Bold"/>
        <DatePicker x:Name="dpActualDate" Grid.Row="8" Grid.Column="1" Margin="0,5"
                    SelectedDate="{Binding ActualCompletionDate}"/>

        <!-- Комментарий -->
        <TextBlock Grid.Row="9" Grid.Column="0" Text="Комментарий:" VerticalAlignment="Top" FontWeight="Bold"/>
        <TextBox x:Name="tbComment" Grid.Row="9" Grid.Column="1" Margin="0,5" Height="60" 
                 TextWrapping="Wrap" Text="{Binding Comment}"/>

        <!-- Кнопки -->
        <StackPanel Grid.Row="11" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="30" 
                    Margin="0,0,10,0" Click="btnSave_Click"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="30" 
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>
