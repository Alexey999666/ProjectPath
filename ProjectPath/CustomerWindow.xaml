<Window x:Class="ProjectPath.CustomerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProjectPath - Управление заказчиками"
        Height="800" Width="1300"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Стили -->
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconButton" TargetType="Button">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="8" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="IconOutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="8" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F0F3F8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <!-- Стиль для текстовых полей -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Кнопка назад -->
                <Button Grid.Column="0" Content="← Назад" Width="100" Height="32" 
                        Click="btnBack_Click" Background="#C0392B" 
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        FontSize="13" Margin="0,0,20,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <!-- Логотип и название -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="#C0392B" CornerRadius="8" Width="40" Height="40" Margin="0,0,10,0">
                        <TextBlock Text="🏢" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Управление заказчиками" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Customer Management" FontSize="10" Foreground="#BDC3C7"/>
                    </StackPanel>
                </StackPanel>

                <!-- Информация о пользователе -->
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#34495E" CornerRadius="15" Padding="10,5">
                        <TextBlock x:Name="tbUserInfo" Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Rectangle Grid.Row="0" Height="3" Fill="#C0392B" VerticalAlignment="Bottom"/>

        <!-- Основное содержимое -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.5*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="1.2*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - список заказчиков -->
            <Border Grid.Column="0" Style="{StaticResource InfoCard}" Margin="0,0,15,0"  >
                <Border.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                
                    <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📋 Список заказчиков" Style="{StaticResource SectionHeader}"/>

                    <!-- Панель поиска -->
                    <Border Grid.Row="1" Background="#F0F3F8" CornerRadius="20" Padding="8,5" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="14" Margin="5,0,8,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="tbSearch" Grid.Column="1" Background="Transparent" 
                                     BorderThickness="0" FontSize="14"
                                     TextChanged="tbSearch_TextChanged"
                                     VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- DataGrid заказчиков -->
                    <DataGrid x:Name="dgCustomers" Grid.Row="2" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="dgCustomers_SelectionChanged"
                              AlternatingRowBackground="#F9FAFC" RowBackground="White"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              FontSize="13">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#C0392B"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding CustomerId}" Width="50"/>
                            <DataGridTextColumn Header="Организация" Binding="{Binding NameOrganization}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Контактное лицо" Binding="{Binding ContactPerson}" Width="150"/>
                            <DataGridTextColumn Header="Телефон" Binding="{Binding Phone}" Width="120"/>
                            <DataGridTextColumn Header="Email" Binding="{Binding Email}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Вертикальный разделитель с кнопками -->
            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0" >
                <Button x:Name="btnInfo" Content="💡" Style="{StaticResource IconOutlineButton}" 
        Click="btnInfo_Click" ToolTip="Подсказка"/>
                <Button x:Name="btnAdd" Content="➕" Style="{StaticResource IconButton}" 
                        Click="btnAdd_Click" ToolTip="Добавить заказчика" Margin="0,10,10,10"/>
                <Button x:Name="btnEdit" Content="✏️" Style="{StaticResource IconOutlineButton}" 
                        Click="btnEdit_Click" ToolTip="Редактировать заказчика"/>
                <Button x:Name="btnDelete" Content="🗑️" Style="{StaticResource DangerButton}" 
                        Click="btnDelete_Click" ToolTip="Удалить заказчика" Width="40" Height="40" Margin="0,10,10,0"/>
            </StackPanel>

            <!-- Правая панель - форма добавления/редактирования -->
            <Border x:Name="editPanel" Grid.Column="2" Style="{StaticResource InfoCard}" Visibility="Collapsed" >
                <Border.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" x:Name="tbFormTitle" Text="Добавление заказчика" 
                               Style="{StaticResource SectionHeader}"/>

                    <!-- Поля формы -->
                    <StackPanel Grid.Row="1" Margin="5,0,5,15">
                        <TextBlock Text="Название организации" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" Margin="0,0,0,5" />
                        <TextBox x:Name="tbNameOrganization"  Height="40" VerticalAlignment="Center" />
                    </StackPanel>

                    <StackPanel Grid.Row="2" Margin="5,0,5,15">
                        <TextBlock Text="Контактное лицо" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" Margin="0,0,0,5"/>
                        <TextBox x:Name="tbContactPerson" VerticalAlignment="Center" Height="40" />
                    </StackPanel>

                    <StackPanel Grid.Row="3" Margin="5,0,5,15">
                        <TextBlock Text="Телефон" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" Margin="0,0,0,5"/>
                        <TextBox x:Name="tbPhone" Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="4" Margin="5,0,5,15">
                        <TextBlock Text="Email" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" Margin="0,0,0,5"/>
                        <TextBox x:Name="tbEmail" Height="40"/>
                    </StackPanel>

                    <StackPanel Grid.Row="5" Margin="5,0,5,15">
                        <TextBlock Text="Адрес" FontWeight="SemiBold" 
                                   Foreground="#2C3E50" Margin="0,0,0,5"/>
                        <TextBox x:Name="tbAdress" Height="60" TextWrapping="Wrap" AcceptsReturn="True" />
                    </StackPanel>

                    <!-- Кнопки формы -->
                    <StackPanel Grid.Row="6" Orientation="Horizontal" Margin="0,0,0,15" HorizontalAlignment="Center">
                        <Button x:Name="btnSave" Content="💾 Сохранить" Style="{StaticResource ActionButton}" 
                                Click="btnSave_Click" Width="100"/>
                        <Button x:Name="btnCancel" Content="❌ Отмена" Style="{StaticResource OutlineButton}" 
                                Click="btnCancel_Click" Width="100"/>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <!-- Нижняя строка состояния -->
        <Border Grid.Row="2" Background="#2C3E50" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="✅ Управление заказчиками" Foreground="#BDC3C7" FontSize="11"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="tbDate" Foreground="#BDC3C7" FontSize="11"/>
                    <TextBlock Text=" | " Foreground="#C0392B" FontSize="11"/>
                    <TextBlock x:Name="tbTime" Foreground="#BDC3C7" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
        <Rectangle Grid.Row="2" Height="2" Fill="#C0392B" VerticalAlignment="Top"/>
    </Grid>
</Window>