<Window x:Class="ProjectPath.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProjectPath - Система управления проектами"
        Height="700" Width="1200"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Стили -->
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="18"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,15"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SuccessButton" TargetType="Button">
            <Setter Property="Background" Value="#27AE60"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="#F0F3F8"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Margin" Value="0,0,10,0"/>
        </Style>

        <!-- Стиль для кнопки меню -->
        <Style x:Key="MenuButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#34495E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль строки DataGrid с цветовой подсветкой -->
        <Style x:Key="HighlightRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
            <Style.Triggers>
                <DataTrigger Binding="{Binding Status}" Value="Активный">
                    <Setter Property="Background" Value="#90EE90"/>
                    <Setter Property="Foreground" Value="Green"/>
                </DataTrigger>
                <DataTrigger Binding="{Binding Status}" Value="Завершён">
                    <Setter Property="Background" Value="#FFB6C1"/>
                    <Setter Property="Foreground" Value="Blue"/>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <!-- Обычный стиль строки без подсветки -->
        <Style x:Key="NormalRowStyle" TargetType="DataGridRow">
            <Setter Property="Background" Value="Transparent"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Логотип и название -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <Border Background="#C0392B" CornerRadius="8" Width="40" Height="40" Margin="0,0,10,0">
                        <TextBlock Text="📊" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Margin="0,0,10,0">
                        <TextBlock Text="Управление проектами" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Project Management System" FontSize="10" Foreground="#BDC3C7"/>
                    </StackPanel>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Menu Background="Transparent" BorderThickness="0" Foreground="White">
                        <MenuItem Header="📄 Страницы" Background="#2C3E50" Foreground="White" FontSize="13">
                            <MenuItem Header="🏢 Заказчики" Click="btnCustomer_Click"  Background="#2C3E50" Foreground="White"/>
                            <MenuItem Header="📦 Номенклатуры" Click="btnNomenclature_Click" Background="#2C3E50" Foreground="White"/>
                            <MenuItem Header="🏪 Склады и Цеха 🏭" Click="btnDepartmentAndWarehouse_Click" Background="#2C3E50" Foreground="White"/>
                           
                        </MenuItem>
                    </Menu>

                    <Menu Background="Transparent" BorderThickness="0" Foreground="White" Margin="15,0,0,0">
                        <MenuItem Header="ℹ️ Информация" Background="#2C3E50" Foreground="White" FontSize="13">
                            <MenuItem x:Name="miHelpMain" Header="📘 Инструкция (главное окно)" Click="miHelp_Click" Background="#2C3E50" Foreground="White"/>
                            <MenuItem x:Name="miHelpProject" Header="📗 Инструкция (проекты)" Click="miHelp_Click" Background="#2C3E50" Foreground="White"/>
                            <MenuItem x:Name="miHelpEvents" Header="📙 Инструкция (события)" Click="miHelp_Click" Background="#2C3E50" Foreground="White"/>
                            <MenuItem x:Name="miHelpAuth" Header="📕 Инструкция (авторизация)" Click="miHelp_Click" Background="#2C3E50" Foreground="White"/>
                        </MenuItem>
                    </Menu>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Border Background="#34495E" CornerRadius="15" Padding="10,5" Margin="20,0,10,0">
                        <TextBlock x:Name="tbUserInfo" Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                    <Button x:Name="btnLogout" Content="Выход" Width="80" Height="32" 
                            Click="btnLogout_Click" Background="#C0392B" 
                            Foreground="White" BorderThickness="0" Cursor="Hand">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="6"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <Rectangle Grid.Row="0" Height="3" Fill="#C0392B" VerticalAlignment="Bottom"/>

        <!-- Основное содержимое -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="1.2*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - список проектов -->
            <Border Grid.Column="0" Style="{StaticResource InfoCard}" Margin="0,0,15,0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📋 Список проектов" Style="{StaticResource SectionHeader}"/>

                    <!-- Статистические карточки -->
                    <WrapPanel Grid.Row="1" Margin="0,0,0,15">
                        <Border Style="{StaticResource StatCard}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📊" FontSize="16" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock x:Name="tbTotalProjects" Text="0" FontSize="14" FontWeight="Bold" Foreground="#2C3E50"/>
                                    <TextBlock Text="Всего проектов" FontSize="10" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="✅" FontSize="16" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock x:Name="tbActiveProjects" Text="0" FontSize="14" FontWeight="Bold" Foreground="#27AE60"/>
                                    <TextBlock Text="Активных" FontSize="10" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <Border Style="{StaticResource StatCard}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🏁" FontSize="16" Margin="0,0,8,0"/>
                                <StackPanel>
                                    <TextBlock x:Name="tbCompletedProjects" Text="0" FontSize="14" FontWeight="Bold" Foreground="#3498DB"/>
                                    <TextBlock Text="Завершённых" FontSize="10" Foreground="#7F8C8D"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </WrapPanel>

                    <!-- Панель поиска -->
                    <Border Grid.Row="2" Background="#F0F3F8" CornerRadius="20" Padding="8,5" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="14" Margin="5,0,8,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="tbSearch" Grid.Column="1" Background="Transparent" 
                                     BorderThickness="0" FontSize="14"
                                     TextChanged="tbSearch_TextChanged"
                                     VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- Кнопки действий -->
                    <StackPanel Grid.Row="3" Orientation="Horizontal" Margin="0,0,0,15">
                        <Button x:Name="btnAdd" Content="➕ Добавить" Style="{StaticResource ActionButton}" Click="btnAdd_Click"/>
                        <Button x:Name="btnEdit" Content="✏️ Редактировать" Style="{StaticResource OutlineButton}" Click="btnEdit_Click"/>
                        <Button x:Name="btnDelete" Content="🗑️ Удалить" Style="{StaticResource DangerButton}" Click="btnDelete_Click"/>
                        <Button x:Name="btnRefresh" Content="🔄" Width="40" Style="{StaticResource OutlineButton}" Padding="0" Click="btnRefresh_Click"/>
                        <Button x:Name="btnToggleHighlight" Content="🎨 Подсветка" Style="{StaticResource SuccessButton}" Click="btnToggleHighlight_Click"/>
                    </StackPanel>

                    <!-- DataGrid проектов -->
                    <DataGrid x:Name="dgProjects" Grid.Row="4" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="dgProjects_SelectionChanged"
                              MouseDoubleClick="dgProjects_MouseDoubleClick"
                              AlternatingRowBackground="#F9FAFC" RowBackground="White"
                              BorderThickness="0"
                              GridLinesVisibility="Horizontal"
                              FontSize="13"
                              RowStyle="{StaticResource NormalRowStyle}">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#C0392B"/>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightTextBrushKey}" Color="White"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProjectId}" Width="50"/>
                            <DataGridTextColumn Header="Название проекта" Binding="{Binding Name}" Width="*">
                                <DataGridTextColumn.ElementStyle>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="FontWeight" Value="SemiBold"/>
                                    </Style>
                                </DataGridTextColumn.ElementStyle>
                            </DataGridTextColumn>
                            <DataGridTextColumn Header="Заказчик"  Binding="{Binding Customer.NameOrganization}" Width="120"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="План" Binding="{Binding PlannedCompletionDate, StringFormat=dd.MM.yyyy}" Width="90"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </Border>

            <!-- Правая панель - детали и история -->
            <Border Grid.Column="1" Style="{StaticResource InfoCard}">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="ℹ️ Информация о проекте" Style="{StaticResource SectionHeader}"/>

                    <!-- Карточка информации о проекте -->
                    <Border x:Name="projectInfoPanel" Grid.Row="1" Background="#FDF2F2" CornerRadius="8" Padding="12" Margin="0,0,0,15" Visibility="Collapsed" BorderBrush="#E74C3C" BorderThickness="1">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="100"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Row="0" Grid.Column="0" Text="Название:" FontWeight="Bold" Foreground="#2C3E50"/>
                            <TextBlock x:Name="tbDetailName" Grid.Row="0" Grid.Column="1" Foreground="#2C3E50"/>

                            <TextBlock Grid.Row="1" Grid.Column="0" Text="Заказчик:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0"/>
                            <TextBlock x:Name="tbDetailCustomer" Grid.Row="1" Grid.Column="1" Foreground="#2C3E50" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="2" Grid.Column="0" Text="Руководитель:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0"/>
                            <TextBlock x:Name="tbDetailSupervisor" Grid.Row="2" Grid.Column="1" Foreground="#2C3E50" Margin="0,8,0,0"/>

                            <TextBlock Grid.Row="3" Grid.Column="0" Text="Статус:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0"/>
                            <Border x:Name="statusBadge" Grid.Row="3" Grid.Column="1" CornerRadius="10" Padding="8,3" Margin="0,8,0,0" HorizontalAlignment="Left">
                                <TextBlock x:Name="tbDetailStatus" Foreground="White" FontSize="11"/>
                            </Border>

                            <TextBlock Grid.Row="4" Grid.Column="0" Text="Даты:" FontWeight="Bold" Foreground="#2C3E50" Margin="0,8,0,0"/>
                            <TextBlock x:Name="tbDetailDates" Grid.Row="4" Grid.Column="1" Foreground="#2C3E50" Margin="0,8,0,0"/>
                        </Grid>
                    </Border>

                    <Border x:Name="noProjectPanel" Grid.Row="1" Background="#F0F3F8" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                        <TextBlock Text="👈 Выберите проект из списка" Foreground="#7F8C8D" FontSize="14" TextAlignment="Center"/>
                    </Border>

                    <!-- Заголовок истории с кнопкой добавления -->
                    <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="📜 История изменений" Style="{StaticResource SectionHeader}" Margin="0,0,15,0"/>
                        <Button x:Name="btnAddEvent" Content="➕ Добавить событие" Style="{StaticResource ActionButton}" Click="btnAddEvent_Click" Visibility="Collapsed" Height="28" Padding="10,0" FontSize="12"/>
                    </StackPanel>

                    <DataGrid x:Name="dgHistory" Grid.Row="3" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              MouseDoubleClick="dgHistory_MouseDoubleClick"
                              AlternatingRowBackground="#F9FAFC" RowBackground="White"
                              BorderThickness="0" GridLinesVisibility="Horizontal" FontSize="13">
                        <DataGrid.Resources>
                            <SolidColorBrush x:Key="{x:Static SystemColors.HighlightBrushKey}" Color="#C0392B"/>
                        </DataGrid.Resources>
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата и время" Binding="{Binding DateExecution, StringFormat=dd.MM.yyyy HH:mm}" Width="140"/>
                            <DataGridTextColumn Header="Тип события" Binding="{Binding TypeOperation}" Width="120"/>
                            <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <TextBlock x:Name="tbEmptyHistory" Grid.Row="3" Text="Нет событий. Нажмите &quot;Добавить событие&quot;" Foreground="#7F8C8D" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Visibility="Collapsed"/>
                </Grid>
            </Border>
        </Grid>

        <!-- Нижняя строка состояния -->
        <Border Grid.Row="2" Background="#2C3E50" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="✅ Готов к работе" Foreground="#BDC3C7" FontSize="11"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="tbDate" Foreground="#BDC3C7" FontSize="11"/>
                    <TextBlock Text=" | " Foreground="#C0392B" FontSize="11"/>
                    <TextBlock x:Name="tbTime" Foreground="#BDC3C7" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
        <Rectangle Grid.Row="2" Height="2" Fill="#C0392B" VerticalAlignment="Top"/>
    </Grid>
</Window>