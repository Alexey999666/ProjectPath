<Window x:Class="ProjectPath.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectPath"
        mc:Ignorable="d"
        Title="Управление проектами" Height="600" Width="900"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#2C3E50" Padding="10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="Система управления проектами" 
                           FontSize="20" Foreground="White" FontWeight="Bold"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="tbUserInfo" Foreground="White" 
                               VerticalAlignment="Center" Margin="0,0,15,0"/>
                    <Button x:Name="btnLogout" Content="Выход" Width="80" 
                            Click="btnLogout_Click" Background="#E74C3C" 
                            Foreground="White" BorderThickness="0"/>
                </StackPanel>
            </Grid>
        </Border>

        <TabControl Grid.Row="1" Margin="10">
            <TabItem Header="Проекты">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="btnAdd" Content="Добавить проект" Width="120" 
                                Margin="0,0,5,0" Click="btnAdd_Click"/>
                        <Button x:Name="btnEdit" Content="Редактировать" Width="100" 
                                Margin="0,0,5,0" Click="btnEdit_Click"/>
                        <Button x:Name="btnDelete" Content="Удалить" Width="100" 
                                Margin="0,0,5,0" Click="btnDelete_Click"/>
                        <Button x:Name="btnRefresh" Content="Обновить" Width="100" 
                                Click="btnRefresh_Click"/>
                    </StackPanel>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Поиск:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="tbSearch" Width="200" 
                                 TextChanged="tbSearch_TextChanged"/>
                    </StackPanel>

                    <DataGrid x:Name="dgProjects" Grid.Row="2" 
                              AutoGenerateColumns="False" IsReadOnly="True"
                              SelectionChanged="dgProjects_SelectionChanged">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="ID" Binding="{Binding ProjectId}" Width="50"/>
                            <DataGridTextColumn Header="Название" Binding="{Binding Name}" Width="200"/>
                            <DataGridTextColumn Header="Заказчик" Binding="{Binding Customer.NameOrganization}" Width="150"/>
                            <DataGridTextColumn Header="Руководитель" Binding="{Binding SupervisorNavigation.LastName}" Width="150"/>
                            <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="100"/>
                            <DataGridTextColumn Header="Дата старта" Binding="{Binding StartDate, StringFormat=d}" Width="100"/>
                            <DataGridTextColumn Header="Плановая дата" Binding="{Binding PlannedCompletionDate, StringFormat=d}" Width="100"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="История проекта" x:Name="tabHistory" IsEnabled="False">
                <Grid Margin="10">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Grid.Row="0" Background="#ECF0F1" Padding="10" Margin="0,0,0,10">
                        <TextBlock x:Name="tbSelectedProject" FontSize="14" FontWeight="Bold"/>
                    </Border>

                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <Button x:Name="btnAddEvent" Content="Добавить событие" Width="130" 
                                Click="btnAddEvent_Click" Margin="0,0,5,0"/>
                        <Button x:Name="btnRefreshHistory" Content="Обновить" Width="100" 
                                Click="btnRefreshHistory_Click"/>
                    </StackPanel>

                    <DataGrid x:Name="dgHistory" Grid.Row="2" 
          AutoGenerateColumns="False" IsReadOnly="True"
          MouseDoubleClick="dgHistory_MouseDoubleClick">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Дата" Binding="{Binding DateExecution, StringFormat=dd.MM.yyyy HH:mm}" Width="150"/>
                            <DataGridTextColumn Header="Тип события" Binding="{Binding TypeOperation}" Width="150"/>
                            <DataGridTextColumn Header="Комментарий" Binding="{Binding Comment}" Width="*"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>
    </Grid>
</Window>
