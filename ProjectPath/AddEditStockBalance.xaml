<Window x:Class="ProjectPath.AddEditStockBalance"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Остатки на складе" Height="350" Width="500"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="120"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Склад:" VerticalAlignment="Center" FontWeight="Bold"/>
        <ComboBox x:Name="cbWarehouse" Grid.Row="0" Grid.Column="1" Margin="0,5" 
                  DisplayMemberPath="Type" SelectedValuePath="WarehouseId"/>

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Количество:" VerticalAlignment="Center" FontWeight="Bold"/>
        <TextBox x:Name="tbQuantity" Grid.Row="1" Grid.Column="1" Margin="0,5"/>

        <StackPanel Grid.Row="6" Grid.ColumnSpan="2" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="btnSave" Content="Сохранить" Width="100" Height="30" 
                    Margin="0,0,10,0" Click="btnSave_Click"/>
            <Button x:Name="btnDelete" Content="Удалить" Width="100" Height="30" 
                    Margin="0,0,10,0" Click="btnDelete_Click" Background="#E74C3C" Foreground="White"/>
            <Button x:Name="btnCancel" Content="Отмена" Width="100" Height="30" 
                    Click="btnCancel_Click"/>
        </StackPanel>
    </Grid>
</Window>