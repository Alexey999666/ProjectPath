<Window x:Class="ProjectPath.DepartmentAndWarehouseWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProjectPath - Карта цехов и складов"
        Height="700" Width="1200"
        WindowStartupLocation="CenterOwner"
        Loaded="Window_Loaded" Closing="Window_Closing">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← Назад" Width="100" Height="32" 
                        Click="btnBack_Click" Background="#C0392B" 
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        FontSize="13">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="#C0392B" CornerRadius="8" Width="40" Height="40" Margin="0,0,10,0">
                        <TextBlock Text="🗺️" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Карта цехов и складов" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Нажмите правой кнопкой на пустое место для добавления" FontSize="10" Foreground="#BDC3C7"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#34495E" CornerRadius="15" Padding="10,5">
                        <TextBlock x:Name="tbUserInfo" Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Rectangle Grid.Row="0" Height="3" Fill="#C0392B" VerticalAlignment="Bottom"/>

        <!-- Контейнер с прокруткой для Canvas -->
        <ScrollViewer Grid.Row="1" HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Auto"
                      Background="#F0F2F5" Margin="10">
            <Border BorderBrush="#D0D0D0" BorderThickness="1" Background="White" 
                    CornerRadius="8" Margin="5">
                <Canvas x:Name="MapCanvas" 
                        Width="2000" Height="1500"
                        Background="LightBlue"
                        MouseRightButtonDown="MapCanvas_MouseRightButtonDown" >
                    <Canvas.ContextMenu>
                        <ContextMenu>
                            <MenuItem Header="Добавить цех" Click="AddDepartment_Click"/>
                            <MenuItem Header="Добавить склад" Click="AddWarehouse_Click"/>
                        </ContextMenu>
                    </Canvas.ContextMenu>
                </Canvas>
            </Border>
        </ScrollViewer>

        <!-- Нижняя строка состояния -->
        <Border Grid.Row="2" Background="#2C3E50" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="✅ Легенда: 🟠 Оранжевый - Склад | 🟢 Зелёный - Цех | Двойной клик - редактирование | Клик правой кнопкой мыши - добавление" 
                           Foreground="#BDC3C7" FontSize="11"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="tbDate" Foreground="#BDC3C7" FontSize="11"/>
                    <TextBlock Text=" | " Foreground="#C0392B" FontSize="11"/>
                    <TextBlock x:Name="tbTime" Foreground="#BDC3C7" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
        <Rectangle Grid.Row="2" Height="2" Fill="#C0392B" VerticalAlignment="Top"/>
    </Grid>
</Window>