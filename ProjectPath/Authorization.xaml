<Window x:Class="ProjectPath.Authorization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectPath"
        mc:Ignorable="d"
        Title="Авторизация" Height="400" Width="450"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Loaded="Window_Loaded">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <TextBlock Grid.Row="0" Text="Вход в систему" FontSize="24" FontWeight="Bold" 
                   HorizontalAlignment="Center" Margin="0,0,0,20"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Логин:" Width="100" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="tbLogin" Width="250" FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,5">
            <TextBlock Text="Пароль:" Width="100" VerticalAlignment="Center" FontSize="14"/>
            <PasswordBox x:Name="pbPassword" Width="250" FontSize="14"/>
        </StackPanel>

        <StackPanel x:Name="spCaptcha" Grid.Row="3" Orientation="Horizontal" Margin="0,5" Visibility="Collapsed">
            <TextBlock Text="CAPTCHA:" Width="100" VerticalAlignment="Center" FontSize="14"/>
            <TextBox x:Name="tbCaptcha" Width="150" FontSize="14" Margin="0,0,10,0"/>
            <TextBlock x:Name="tbCaptchaCode" Width="80" FontSize="16" FontWeight="Bold" 
                       TextAlignment="Center" VerticalAlignment="Center" 
                       Background="LightGray" Padding="5"/>
        </StackPanel>

        <StackPanel Grid.Row="4" Orientation="Horizontal" 
                    HorizontalAlignment="Center" Margin="0,20">
            <Button x:Name="btnLogin" Content="Войти" Width="100" Height="30" 
                    Margin="0,0,10,0" Click="btnLogin_Click"/>
            <Button x:Name="btnGuest" Content="Войти как гость" Width="120" Height="30" 
                    Click="btnGuest_Click"/>
            <Button x:Name="btnClose" Content="Отмена" Width="120" Height="30" 
                    Click="btnClose_Click" Margin="10,0,0,0"/>
        </StackPanel>

        <TextBlock x:Name="tbStatus" Grid.Row="5" Foreground="Red" 
                   HorizontalAlignment="Center" Margin="0,10"/>
    </Grid>
</Window>
