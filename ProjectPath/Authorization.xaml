<Window x:Class="ProjectPath.Authorization"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ProjectPath"
        mc:Ignorable="d"
        Title="Авторизация" Height="500" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        WindowStyle="None" AllowsTransparency="True"
        Loaded="Window_Loaded">

    <Window.Resources>
        <!-- Стиль для кнопки входа -->
        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#A93226"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки "Гость" -->
        <Style x:Key="GuestButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#ECF0F1"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для текстовых полей -->
        <Style TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Height" Value="35"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Background" Value="White"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="PasswordBox">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="#2C3E50">
        <Border Background="White" Margin="3" CornerRadius="12">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" ShadowDepth="3" Opacity="0.2"/>
            </Border.Effect>

            <Grid Margin="30,25">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                

                <!-- Логотип и заголовок -->
                <StackPanel Grid.Row="1" Orientation="Horizontal" 
                            HorizontalAlignment="Center" Margin="0,10,0,25">
                    <Border Background="#C0392B" CornerRadius="10" Width="45" Height="45" Margin="0,0,12,0">
                        <TextBlock Text="📊" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Управление проектами" FontSize="18" FontWeight="Bold" Foreground="#2C3E50"/>
                        <TextBlock Text="Project Management System" FontSize="10" Foreground="#7F8C8D"/>
                    </StackPanel>
                </StackPanel>

                <!-- Поле Логин -->
                <StackPanel Grid.Row="2" Margin="0,5">
                    <TextBlock Text="Логин" FontSize="12" Foreground="#7F8C8D" Margin="5,0,0,5"/>
                    <TextBox x:Name="tbLogin" Height="40" FontSize="14" KeyDown="tbLogin_KeyDown">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </StackPanel>

                <!-- Поле Пароль -->
                <StackPanel Grid.Row="3" Margin="0,15,0,5">
                    <TextBlock Text="Пароль" FontSize="12" Foreground="#7F8C8D" Margin="5,0,0,5"/>
                    <PasswordBox x:Name="pbPassword" Height="40" FontSize="14" KeyDown="pbPassword_KeyDown">
                        <PasswordBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </PasswordBox.Resources>
                    </PasswordBox>
                </StackPanel>

                <!-- CAPTCHA блок -->
                <StackPanel x:Name="spCaptcha" Grid.Row="4" Margin="0,15,0,5" Visibility="Collapsed">
                    <TextBlock Text="Подтверждение" FontSize="12" Foreground="#7F8C8D" Margin="5,0,0,5" KeyDown="tbCaptcha_KeyDown"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox x:Name="tbCaptcha" Grid.Column="0" Height="40" FontSize="14" Margin="0,0,10,0">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="8"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        <Border Grid.Column="1" Background="#F0F3F8" CornerRadius="8" 
                                Width="100" Height="40" BorderBrush="#BDC3C7" BorderThickness="1">
                            <TextBlock x:Name="tbCaptchaCode" FontSize="18" FontWeight="Bold" 
                                       TextAlignment="Center" VerticalAlignment="Center" 
                                       Foreground="#2C3E50"/>
                        </Border>
                    </Grid>
                </StackPanel>

                <!-- Кнопки -->
                <StackPanel Grid.Row="5" Orientation="Horizontal" 
                            HorizontalAlignment="Center" Margin="0,25,0,10">
                    <Button x:Name="btnLogin" Content="ВОЙТИ" Width="120" Height="38" 
                            Style="{StaticResource LoginButton}" Click="btnLogin_Click"/>
                    <Button x:Name="btnGuest" Content="Войти как гость" Width="140" Height="38" 
                            Style="{StaticResource GuestButton}" Click="btnGuest_Click" Margin="10,0,0,0"/>
                    <Button x:Name="btnDel" Content="Отмена" Width="140" Height="38" 
        Style="{StaticResource GuestButton}" Click="btnClose_Click" Margin="10,0,0,0"/>
                </StackPanel>

                

                <!-- Статус сообщение -->
                <TextBlock x:Name="tbStatus" Grid.Row="6" Foreground="#E74C3C" 
                           HorizontalAlignment="Center" Margin="0,15,0,0" 
                           FontSize="12" TextWrapping="Wrap" TextAlignment="Center"/>
            </Grid>
        </Border>
    </Border>
</Window>