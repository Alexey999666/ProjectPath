<Window x:Class="ProjectPath.Nomenclature"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ProjectPath - Управление номенклатурой"
        Height="700" Width="1700"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded" Closing="Window_Closing">

    <Window.Resources>
        <!-- Стили -->
        <Style x:Key="InfoCard" TargetType="Border">
            <Setter Property="Background" Value="White"/>
            <Setter Property="CornerRadius" Value="12"/>
            <Setter Property="BorderBrush" Value="#E0E0E0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.1"/>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="SectionHeader" TargetType="TextBlock">
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="Margin" Value="0,0,0,10"/>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#C0392B"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="OutlineButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#2C3E50"/>
            <Setter Property="BorderBrush" Value="#BDC3C7"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderBrush="{TemplateBinding BorderBrush}" 
                                BorderThickness="{TemplateBinding BorderThickness}" 
                                CornerRadius="6" 
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="DangerButton" TargetType="Button">
            <Setter Property="Background" Value="#E74C3C"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Margin" Value="0,0,8,0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="6" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Стиль для ListViewItem -->
        <Style TargetType="ListViewItem">
            <Setter Property="Padding" Value="0"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="#C0392B"/>
                    <Setter Property="Foreground" Value="White"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Верхняя панель -->
        <Border Grid.Row="0" Background="#2C3E50" Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Button Grid.Column="0" Content="← Назад" Width="100" Height="32" 
                        Click="btnBack_Click" Background="#C0392B" 
                        Foreground="White" BorderThickness="0" Cursor="Hand"
                        FontSize="13" Margin="0,0,20,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="6"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Center">
                    <Border Background="#C0392B" CornerRadius="8" Width="40" Height="40" Margin="0,0,10,0">
                        <TextBlock Text="📦" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel>
                        <TextBlock Text="Управление номенклатурой" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="Nomenclature Management" FontSize="10" Foreground="#BDC3C7"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Border Background="#34495E" CornerRadius="15" Padding="10,5">
                        <TextBlock x:Name="tbUserInfo" Foreground="White" VerticalAlignment="Center"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <Rectangle Grid.Row="0" Height="3" Fill="#C0392B" VerticalAlignment="Bottom"/>

        <!-- Основное содержимое -->
        <Grid Grid.Row="1" Margin="20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Левая панель - список номенклатуры -->
            <Border Grid.Column="0" Style="{StaticResource InfoCard}" Margin="0,0,15,0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="📋 Список номенклатуры" Style="{StaticResource SectionHeader}"/>

                    <!-- Новая панель поиска -->
                    <Border Grid.Row="1" Background="#F0F3F8" CornerRadius="20" Padding="8,5" Margin="0,0,0,15">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" FontSize="14" Margin="5,0,8,0" VerticalAlignment="Center"/>
                            <TextBox x:Name="tbSearch" Grid.Column="1" Background="Transparent" 
                                     BorderThickness="0" FontSize="14"
                                     TextChanged="tbSearch_TextChanged"
                                     VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <!-- ListView номенклатуры -->
                    <ListView x:Name="lvNomenclature" Grid.Row="3" SelectionChanged="lvNomenclature_SelectionChanged">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <StackPanel Margin="10,0,0,0">
                                            <TextBlock Text="{Binding Name, StringFormat=Наименование: {0}}" />
                                            <TextBlock Text="{Binding Type, StringFormat=Тип: {0}}" />
                                            <TextBlock Text="{Binding UnitMeasure, StringFormat=Ед. изм.: {0}}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>


            <!-- Центральная панель - фото -->
            <Border Grid.Column="1" Style="{StaticResource InfoCard}" Margin="15,0,15,0">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🖼️ Изображение" Style="{StaticResource SectionHeader}" Margin="0,0,0,15"/>

                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center">
                        <Image x:Name="ProductImage" 
                   Width="400" 
                   Height="400" 
                   Stretch="Uniform"
                   Margin="0,0,0,10"/>
                        <TextBlock x:Name="NoImageText" 
                       Text="Изображение не выбрано" 
                       Foreground="#7F8C8D"
                       FontSize="12"
                       HorizontalAlignment="Center"
                       Visibility="Collapsed"/>
                    </StackPanel>
                </Grid>
            </Border>


            <!-- Правая панель - остатки на складах -->
            <Border Grid.Column="2" Style="{StaticResource InfoCard}">
                <Border.Background>
                    <LinearGradientBrush EndPoint="0,1" StartPoint="0,0">
                        <GradientStop Color="#FFFFFF" Offset="0"/>
                        <GradientStop Color="#F8F9FA" Offset="1"/>
                    </LinearGradientBrush>  
                </Border.Background>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="🏭 Остатки на складах" Style="{StaticResource SectionHeader}"/>

                    <!-- Информация о выбранной номенклатуре -->
                    <Border Grid.Row="1" Background="#F0F3F8" CornerRadius="8" Padding="15" Margin="0,0,0,15">
                        <TextBlock x:Name="tbSelectedInfo" Text="Выберите номенклатуру" 
                                   FontWeight="SemiBold" FontSize="14" TextAlignment="Center"/>
                    </Border>

                    <!-- Блок с общей суммой -->
                    <Border Grid.Row="2" Background="#27AE60" CornerRadius="8" Padding="10" Margin="0,0,0,15">
                        <TextBlock x:Name="tbTotalQuantity" Text="Всего на складах: 0 шт." 
                                   Foreground="White" FontWeight="Bold" FontSize="14" 
                                   TextAlignment="Center"/>
                    </Border>

                    <!-- ListView остатков с номером склада -->
                    <ListView x:Name="lvStockBalances" Grid.Row="3" MouseDoubleClick="lvStockBalances_MouseDoubleClick"
          MouseRightButtonDown="lvStockBalances_MouseRightButtonDown">
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid>
                                    <Border BorderBrush="#E0E0E0" BorderThickness="0,0,0,1" Padding="10,8">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                        
                                            <Border Grid.Column="0" Background="#34495E" CornerRadius="8" 
                                Padding="8,4" HorizontalAlignment="Left">
                                                <TextBlock Text="{Binding Warehouse.WarehouseId, StringFormat=Склад №{0}}" 
                                       Foreground="White" FontWeight="Bold" FontSize="11"/>
                                            </Border>

                                           
                                            <StackPanel Grid.Column="1" Margin="15,0,15,0">
                                                <TextBlock Text="{Binding Warehouse.Type}" FontWeight="SemiBold" FontSize="13"/>
                                            </StackPanel>

                                            
                                           
                                            <Border Grid.Column="2" Background="#27AE60" CornerRadius="15" Padding="10,5">
                                                <TextBlock Foreground="White" FontWeight="SemiBold" FontSize="12"
               Text="{Binding Quantity, StringFormat=\{0:F2\}}"/>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </Grid>

        <!-- Кнопки действий -->
        <StackPanel Grid.Row="2" Orientation="Horizontal" Margin="0,15,0,15" HorizontalAlignment="Center" VerticalAlignment="Center">
            <Button x:Name="btnAdd" Content="➕ Добавить" Style="{StaticResource ActionButton}" 
                    Click="btnAdd_Click" Width="100"/>
            <Button x:Name="btnEdit" Content="✏️ Редактировать" Style="{StaticResource OutlineButton}" 
                    Click="btnEdit_Click" />
            <Button x:Name="btnDelete" Content="🗑️ Удалить" Style="{StaticResource DangerButton}" 
                    Click="btnDelete_Click" Width="100"/>
            <Button x:Name="btnRefresh" Content="🔄" Width="40" Style="{StaticResource OutlineButton}" 
                    Padding="0" Click="btnRefresh_Click"/>
            <Button x:Name="btnInfo" Content="💡" Style="{StaticResource OutlineButton}" 
                    Click="btnInfo_Click" ToolTip="Подсказка"/>
        </StackPanel>

        <!-- Нижняя строка состояния -->
        <Border Grid.Row="3" Background="#2C3E50" Padding="10,5">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="✅ Управление номенклатурой" Foreground="#BDC3C7" FontSize="11"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock x:Name="tbDate" Foreground="#BDC3C7" FontSize="11"/>
                    <TextBlock Text=" | " Foreground="#C0392B" FontSize="11"/>
                    <TextBlock x:Name="tbTime" Foreground="#BDC3C7" FontSize="11"/>
                </StackPanel>
            </Grid>
        </Border>
        <Rectangle Grid.Row="3" Height="2" Fill="#C0392B" VerticalAlignment="Top"/>
    </Grid>
</Window>